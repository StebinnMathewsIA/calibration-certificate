# Prowalco calibration backend — environment configuration
# Copy to .env (never commit .env). Setup guide: docs/supabase-setup.md
#
# There is ONE architecture: Supabase Postgres + Storage + Auth, in every
# environment INCLUDING the test suite. The app refuses to start (and tests
# refuse to run) until the Supabase values below are filled in.

# --- Database (Supabase Postgres) ---
# Use the SESSION pooler connection string (Dashboard -> Connect -> Session
# pooler), with the SQLAlchemy driver prefix and TLS:
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- Supabase project (auth + signed-PDF storage) ---
SUPABASE_URL=https://<project-ref>.supabase.co
# Server-only key — full access to Storage and the Auth admin API.
# NEVER ships in the mobile app; the app only ever holds the anon key.
SUPABASE_SERVICE_ROLE_KEY=
# Publishable anon key (same one the mobile app uses).
SUPABASE_ANON_KEY=
# Only needed for legacy projects still on the shared HS256 JWT secret.
# Leave empty to verify tokens via the project JWKS (recommended).
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=certificates

# --- Signing ---
# local   = key on disk, generate with scripts/generate_dev_signing_cert.py
#           (self-signed; replace before real certificates are relied on)
# aws_kms = KMS-held key (stub in PoC — see app/signing/keys.py)
SIGNING_KEY_PROVIDER=local
SIGNING_KEY_DIR=./dev-keys
# RFC 3161 trusted timestamp authority (recommended in production).
TSA_URL=

# --- Claude analysis ---
# The SDK reads ANTHROPIC_API_KEY from the environment. NEVER put this key in
# the mobile app bundle — analysis is always proxied through this backend.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANALYSIS_ENABLED=true
