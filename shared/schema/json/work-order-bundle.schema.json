{
  "$ref": "#/definitions/WorkOrderBundle",
  "definitions": {
    "WorkOrderBundle": {
      "type": "object",
      "properties": {
        "workOrder": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "reference": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "assignedTechnicianEmail": {
              "type": "string",
              "format": "email"
            },
            "siteId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "dispenserIds": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "default": []
            },
            "status": {
              "type": "string",
              "enum": [
                "open",
                "in_progress",
                "completed"
              ],
              "default": "open"
            },
            "scheduledDate": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          },
          "required": [
            "id",
            "reference",
            "assignedTechnicianEmail",
            "siteId"
          ],
          "additionalProperties": false
        },
        "site": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "customerName": {
              "type": "string",
              "maxLength": 200
            },
            "siteName": {
              "type": "string",
              "maxLength": 200
            },
            "address": {
              "type": "string",
              "maxLength": 500
            },
            "telephone": {
              "type": "string",
              "maxLength": 64
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false
        },
        "dispensers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "siteId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "make": {
                "type": "string",
                "maxLength": 100
              },
              "model": {
                "type": "string",
                "maxLength": 100
              },
              "serialNumber": {
                "type": "string",
                "maxLength": 100
              },
              "saApprovalNumber": {
                "type": "string",
                "maxLength": 100
              }
            },
            "required": [
              "id",
              "siteId"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "required": [
        "workOrder",
        "site"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
