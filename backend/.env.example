# Prowalco calibration backend — environment configuration
# Copy to .env (never commit .env)

# --- Database ---
# Dev default is a local SQLite file. Production: Postgres, with the audit
# table locked down per migrations/001_init.sql (append-only role).
DATABASE_URL=sqlite:///./prowalco_dev.sqlite3

# --- Auth (OIDC broker: Auth0 / Firebase Auth / AWS Cognito) ---
# AUTH_MODE=jwks verifies Bearer tokens against the broker's JWKS endpoint.
# AUTH_MODE=disabled bypasses verification (LOCAL DEV ONLY).
AUTH_MODE=disabled
AUTH_JWKS_URL=https://YOUR_TENANT/.well-known/jwks.json
AUTH_ISSUER=https://YOUR_TENANT/
AUTH_AUDIENCE=prowalco-calibration-api

# --- Signing ---
# local     = dev key on disk (generate with scripts/generate_dev_signing_cert.py)
# aws_kms   = AWS KMS-held key (stub in PoC — see app/signing/keys.py)
# azure_kv  = Azure Key Vault (stub in PoC)
SIGNING_KEY_PROVIDER=local
SIGNING_KEY_DIR=./dev-keys
# RFC 3161 trusted timestamp authority. Leave empty in dev (signature is
# still applied, timestamped with the server clock inside the CMS).
TSA_URL=

# --- Claude analysis ---
# The SDK reads ANTHROPIC_API_KEY from the environment. NEVER put this key in
# the mobile app bundle — analysis is always proxied through this backend.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANALYSIS_ENABLED=true
