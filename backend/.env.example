# Prowalco calibration backend — environment configuration
# Copy to .env (never commit .env). Supabase setup: docs/supabase-setup.md

# --- Database ---
# Dev default is a local SQLite file (works out of the box, incl. tests).
# Production: the Supabase Postgres connection string. Use the SESSION pooler
# (port 5432 on the pooler host) or the direct connection; append
# ?sslmode=require. Example:
# DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=sqlite:///./prowalco_dev.sqlite3

# --- Supabase project (auth + signed-PDF storage) ---
SUPABASE_URL=https://<project-ref>.supabase.co
# Server-only key — full access to Storage and (via PostgREST) the DB.
# NEVER ships in the mobile app; the app only ever holds the anon key.
SUPABASE_SERVICE_ROLE_KEY=
# Only needed for legacy projects still on the shared HS256 JWT secret.
# Leave empty to verify tokens via the project JWKS (recommended).
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=certificates

# --- Auth ---
# supabase = verify Supabase Auth JWTs (production)
# jwks     = generic OIDC broker (kept for portability)
# disabled = LOCAL DEV ONLY
AUTH_MODE=disabled
# Only used with AUTH_MODE=jwks:
AUTH_JWKS_URL=
AUTH_ISSUER=
AUTH_AUDIENCE=

# --- Signed PDF storage ---
# db       = keep PDF bytes in the certificates table (dev/tests)
# supabase = private Supabase Storage bucket (production)
PDF_STORAGE=db

# --- Signing ---
# local     = dev key on disk (generate with scripts/generate_dev_signing_cert.py)
# aws_kms   = AWS KMS-held key (stub in PoC — see app/signing/keys.py)
SIGNING_KEY_PROVIDER=local
SIGNING_KEY_DIR=./dev-keys
# RFC 3161 trusted timestamp authority. Leave empty in dev.
TSA_URL=

# --- Claude analysis ---
# The SDK reads ANTHROPIC_API_KEY from the environment. NEVER put this key in
# the mobile app bundle — analysis is always proxied through this backend.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANALYSIS_ENABLED=true
