{
  "$ref": "#/definitions/Verification",
  "definitions": {
    "Verification": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 2
        },
        "certificateNumber": {
          "type": "string",
          "pattern": "^PWC-[A-Z]{2,5}-\\d{6}-\\d{2}$"
        },
        "nrcsBookNumber": {
          "type": "string",
          "maxLength": 32
        },
        "reportType": {
          "type": "string",
          "enum": [
            "verification",
            "repair"
          ]
        },
        "site": {
          "type": "object",
          "properties": {
            "customerName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "siteName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "address": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "telephone": {
              "type": "string",
              "maxLength": 64
            }
          },
          "required": [
            "customerName",
            "siteName",
            "address"
          ],
          "additionalProperties": false
        },
        "jobReference": {
          "type": "string",
          "maxLength": 64
        },
        "workOrderId": {
          "type": "string",
          "maxLength": 64
        },
        "dispenser": {
          "type": "object",
          "properties": {
            "dispenserId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "makeModel": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "saApprovalNumber": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "serialNumber": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100
            },
            "securitySealNumber": {
              "type": "string",
              "maxLength": 64
            }
          },
          "required": [
            "dispenserId",
            "makeModel",
            "saApprovalNumber",
            "serialNumber"
          ],
          "additionalProperties": false
        },
        "referenceMeasures": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": {
                "type": "string",
                "enum": [
                  "200L",
                  "20L",
                  "5L"
                ]
              },
              "serialNumber": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "certificateNumber": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "calibrationDate": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "expiryDate": {
                "$ref": "#/definitions/Verification/properties/referenceMeasures/items/properties/calibrationDate"
              }
            },
            "required": [
              "size",
              "serialNumber",
              "certificateNumber",
              "calibrationDate",
              "expiryDate"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "methodReference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "hoses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hoseNumber": {
                "type": "string",
                "minLength": 1,
                "maxLength": 32
              },
              "product": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64
              },
              "status": {
                "type": "string",
                "enum": [
                  "new",
                  "repaired",
                  "atu",
                  "rejected"
                ]
              },
              "components": {
                "type": "object",
                "properties": {
                  "meter": {
                    "type": "object",
                    "properties": {
                      "make": {
                        "type": "string",
                        "maxLength": 100
                      },
                      "model": {
                        "type": "string",
                        "maxLength": 100
                      },
                      "serial": {
                        "type": "string",
                        "maxLength": 100
                      },
                      "saApproval": {
                        "type": "string",
                        "maxLength": 100
                      }
                    },
                    "additionalProperties": false
                  },
                  "pcBoard": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/components/properties/meter"
                  },
                  "pulsar": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/components/properties/meter"
                  },
                  "solenoid": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/components/properties/meter"
                  }
                },
                "required": [
                  "meter",
                  "pcBoard",
                  "pulsar",
                  "solenoid"
                ],
                "additionalProperties": false
              },
              "securitySeal": {
                "type": "string",
                "maxLength": 64
              },
              "totalizerBefore": {
                "type": "number"
              },
              "totalizerAfter": {
                "type": "number"
              },
              "quantityDelivered": {
                "type": "number"
              },
              "testCondition": {
                "type": "string",
                "enum": [
                  "hot",
                  "cold"
                ]
              },
              "qMinLpm": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "qMaxLpm": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "checklist": {
                "type": "object",
                "properties": {
                  "constructionMarking": {
                    "type": "string",
                    "enum": [
                      "pass",
                      "fail",
                      "na"
                    ]
                  },
                  "computerComputation": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "hydraulics": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "interlockingDevices": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "hoseNozzleAutoStop": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "solenoidValveTest": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "presetTest": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "measuresConformSans1698": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "timeOut": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "nozzleBurst": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  },
                  "zeroSetting": {
                    "$ref": "#/definitions/Verification/properties/hoses/items/properties/checklist/properties/constructionMarking"
                  }
                },
                "required": [
                  "constructionMarking",
                  "computerComputation",
                  "hydraulics",
                  "interlockingDevices",
                  "hoseNozzleAutoStop",
                  "solenoidValveTest",
                  "presetTest",
                  "measuresConformSans1698",
                  "timeOut",
                  "nozzleBurst",
                  "zeroSetting"
                ],
                "additionalProperties": false
              },
              "deliveries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "point": {
                      "type": "string",
                      "enum": [
                        "del1_max",
                        "del2_max",
                        "del3_max",
                        "min_flow",
                        "preset"
                      ]
                    },
                    "flowRateLpm": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "vfdMl": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "vrefMl": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "efdPercent": {
                      "type": "number"
                    },
                    "pass": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "point",
                    "flowRateLpm",
                    "vfdMl",
                    "vrefMl",
                    "efdPercent",
                    "pass"
                  ],
                  "additionalProperties": false
                },
                "minItems": 1
              },
              "outcome": {
                "type": "string",
                "enum": [
                  "certified",
                  "rejected"
                ]
              },
              "comments": {
                "type": "string",
                "maxLength": 2000
              }
            },
            "required": [
              "hoseNumber",
              "product",
              "status",
              "components",
              "testCondition",
              "checklist",
              "deliveries",
              "outcome"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "signOff": {
          "type": "object",
          "properties": {
            "vo": {
              "type": "object",
              "properties": {
                "identity": {
                  "type": "object",
                  "properties": {
                    "subject": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 200
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 200
                    },
                    "authMethod": {
                      "type": "string",
                      "enum": [
                        "microsoft",
                        "google",
                        "apple"
                      ]
                    }
                  },
                  "required": [
                    "subject",
                    "name",
                    "authMethod"
                  ],
                  "additionalProperties": false
                },
                "pliersNumber": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64
                }
              },
              "required": [
                "identity",
                "pliersNumber"
              ],
              "additionalProperties": false
            },
            "client": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200
                }
              },
              "required": [
                "name"
              ],
              "additionalProperties": false
            },
            "declarationAccepted": {
              "type": "boolean"
            },
            "expiryDate": {
              "$ref": "#/definitions/Verification/properties/referenceMeasures/items/properties/calibrationDate"
            },
            "rejectionCertNumber": {
              "type": "string",
              "maxLength": 100
            }
          },
          "required": [
            "vo",
            "client",
            "declarationAccepted"
          ],
          "additionalProperties": false
        },
        "verificationDate": {
          "$ref": "#/definitions/Verification/properties/referenceMeasures/items/properties/calibrationDate"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "prefilled": {
                "type": "boolean"
              },
              "source": {
                "type": "string",
                "enum": [
                  "manual",
                  "onkey"
                ]
              },
              "overridden": {
                "type": "boolean"
              }
            },
            "required": [
              "prefilled",
              "source"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "schemaVersion",
        "certificateNumber",
        "reportType",
        "site",
        "dispenser",
        "referenceMeasures",
        "methodReference",
        "hoses",
        "signOff",
        "verificationDate"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
