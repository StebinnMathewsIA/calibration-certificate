{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8000",
        "EXPO_PUBLIC_AUTH_ISSUER": "https://YOUR_TENANT",
        "EXPO_PUBLIC_AUTH_CLIENT_ID": "DEV_CLIENT_ID"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://calibration-api.staging.prowalco.example",
        "EXPO_PUBLIC_AUTH_ISSUER": "https://YOUR_TENANT",
        "EXPO_PUBLIC_AUTH_CLIENT_ID": "STAGING_CLIENT_ID"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://calibration-api.prowalco.example",
        "EXPO_PUBLIC_AUTH_ISSUER": "https://YOUR_TENANT",
        "EXPO_PUBLIC_AUTH_CLIENT_ID": "PROD_CLIENT_ID"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
